---
import BlogPostCard from '../components/BlogPostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TimelineList from '../components/TimelineList.astro';
import Typewriter from '../components/Typewriter.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHomePageData, getSiteData } from '../lib/content';

const [site, page] = await Promise.all([getSiteData(), getHomePageData()]);
---

<BaseLayout title={site.seo.title} description={site.seo.description} navigation={site.navigation.items} pathname="/">
	<section class="home-flow">
		<section class="hero-intro section">
			<span class="eyebrow" data-animate="fade" data-delay="100">{page.home.hero.eyebrow}</span>
			<h1 class="hero-title" data-animate="fade" data-delay="200">
				<Typewriter text={page.profile.name} speed={90} />
			</h1>
			<p class="hero-subtitle" data-animate data-delay="400">{page.profile.headline}</p>
			<div class="cta-row" data-animate data-delay="600">
				<a class="button" href={page.home.hero.primaryCta.href}>{page.home.hero.primaryCta.label}</a>
				<a class="button-secondary" href={`mailto:${page.profile.email}`}>Email</a>
			</div>
		</section>

		<section class="home-section section">
			<div data-animate>
				<SectionHeader title="Selected projects" description="Projects that explain what I build and how I think." linkHref={`${import.meta.env.BASE_URL}projects`} linkLabel="All projects" />
			</div>
			<div class="editorial-list">
				{page.featuredProjects.map((project, i) => (
					<div data-animate data-delay={String(i * 120)}>
						<ProjectCard project={project} />
					</div>
				))}
			</div>
		</section>

		{page.latestPosts.length > 0 && (
			<section class="home-section section">
				<div data-animate>
					<SectionHeader eyebrow="Writing" title="Latest posts" linkHref={`${import.meta.env.BASE_URL}blog`} linkLabel="All posts" />
				</div>
				<div class="blog-list-compact">
					{page.latestPosts.map((post, i) => (
						<a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="blog-row" data-animate data-delay={String(i * 80)}>
							<time class="blog-row-date">{post.date ? new Date(post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : ''}</time>
							<span class="blog-row-title">{post.title}</span>
							{post.featured && <span class="blog-row-badge">*</span>}
						</a>
					))}
				</div>
			</section>
		)}

		<section class="home-section section">
			<div data-animate>
				<SectionHeader title="Recent trajectory" linkHref={`${import.meta.env.BASE_URL}timeline`} linkLabel="Full timeline" />
			</div>
			<TimelineList items={page.timelinePreview} />
		</section>

		<section class="home-section section compact-section">
			<div data-animate>
				<SectionHeader title="Focus areas" />
			</div>
			<ul class="tag-list muted-tags">
				{page.profile.skills.map((skill, i) => (
					<li class="tag" data-animate="fade" data-delay={String(i * 80)}>{skill}</li>
				))}
			</ul>
		</section>
	</section>
</BaseLayout>
