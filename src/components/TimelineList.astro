---
import type { TimelineItem } from '../types/content';

type Props = {
	items: TimelineItem[];
};

const { items } = Astro.props;
---

<div class="timeline-list">
	{items.map((item) => (
		<article class="timeline-item">
			<span class="timeline-time">{item.start} — {item.end}</span>
			<h3>{item.role}</h3>
			<p>{item.organization}</p>
			<p>{item.summary}</p>
		</article>
	))}
</div>
