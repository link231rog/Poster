---
import type { TimelineItem } from '../types/content';

type Props = {
	items: TimelineItem[];
};

const { items } = Astro.props;
---

<div class="timeline-list">
	{items.map((item, i) => (
		<article class="timeline-item" data-animate="slide-right" data-delay={String(i * 120)}>
			<div class="timeline-date">{item.start} - {item.end}</div>
			<div class="timeline-body">
				<h3>{item.role}</h3>
				<p class="timeline-org">{item.organization}</p>
				<p>{item.summary}</p>
			</div>
		</article>
	))}
</div>
