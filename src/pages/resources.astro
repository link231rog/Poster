---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getResourcesPageData, getSiteData } from '../lib/content';

const [site, page] = await Promise.all([getSiteData(), getResourcesPageData()]);
---

<BaseLayout title={`Resources · ${site.seo.title}`} description="Reading, tools, and references." navigation={site.navigation.items} pathname="/resources">
	<section class="section">
		<span class="eyebrow">Resources</span>
		<h1 class="page-title">Tools, reading, and systems I keep coming back to.</h1>
		<div class="card prose">
			<p>{page.intro}</p>
		</div>
		<div class="grid-2">
			{page.groups.map((group) => (
				<section class="card resource-group">
					<h2>{group.category}</h2>
					{group.items.map((item) => (
						<div class="resource-item">
							<div class="section">
								<a href={item.url} target="_blank" rel="noreferrer">{item.name}</a>
								<p>{item.note}</p>
							</div>
							<span class="resource-note">external</span>
						</div>
					))}
				</section>
			))}
		</div>
	</section>
</BaseLayout>
