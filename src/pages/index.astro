---
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TimelineList from '../components/TimelineList.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHomePageData, getSiteData } from '../lib/content';

const [site, page] = await Promise.all([getSiteData(), getHomePageData()]);
---

<BaseLayout title={site.seo.title} description={site.seo.description} navigation={site.navigation.items} pathname="/">
	<section class="home-flow">
		<section class="hero-intro section">
			<span class="eyebrow">{page.home.hero.eyebrow}</span>
			<h1 class="hero-title">{page.profile.name}</h1>
			<p class="hero-subtitle">{page.profile.headline}</p>
			<p class="hero-lead">{page.profile.shortBio}</p>
			<div class="cta-row">
				<a class="button" href={page.home.hero.primaryCta.href}>{page.home.hero.primaryCta.label}</a>
				<a class="button-secondary" href={`mailto:${page.profile.email}`}>Email</a>
			</div>
			<ul class="inline-list quiet-list">
				<li>
					<span class="status-pill"><span class="status-dot"></span>{page.profile.status.text}</span>
				</li>
				<li>{page.profile.currentFocus}</li>
				<li>{page.profile.location}</li>
			</ul>
			<ul class="social-list text-links">
				{page.profile.socials.map((social) => (
					<li><a href={social.url} target="_blank" rel="noreferrer">{social.label}</a></li>
				))}
			</ul>
		</section>

		<section class="home-section section">
			<SectionHeader eyebrow="Featured work" title="Selected projects" description="A small set of projects that explain what I build, how I think, and where I spend time." linkHref={`${import.meta.env.BASE_URL}projects`} linkLabel="All projects" />
			<div class="editorial-list">
				{page.featuredProjects.map((project) => <ProjectCard project={project} />)}
			</div>
		</section>

		<section class="home-section section">
			<SectionHeader eyebrow="Timeline" title="Recent trajectory" description="A short reading view of current work, research, and milestones." linkHref={`${import.meta.env.BASE_URL}timeline`} linkLabel="Full timeline" />
			<TimelineList items={page.timelinePreview} />
		</section>

		<section class="home-section section compact-section">
			<SectionHeader eyebrow="Current focus" title="What I am optimizing for right now" description="A compact summary of tools, interests, and the work themes shaping the next few projects." />
			<ul class="tag-list muted-tags">
				{page.profile.skills.map((skill) => <li class="tag">{skill}</li>)}
			</ul>
		</section>
	</section>
</BaseLayout>
