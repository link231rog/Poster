---
/**
 * SplitLayout.astro - Brittany Chiang style split layout.
 * Left: sticky sidebar. Right: scrollable content.
 */
import type { NavigationItem, Profile } from '../types/content';
import Sidebar from '../components/Sidebar.astro';
import AnimateOnScroll from '../components/AnimateOnScroll.astro';
import ParticleField from '../components/ParticleField.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import '../styles/global.css';

type Props = {
	title: string;
	description: string;
	navigation: NavigationItem[];
	profile: Profile;
	pathname?: string;
	activeSection?: string;
	sidebarSections: Array<{ id: string; label: string }>;
};

const { title, description, navigation, profile, pathname = '/', activeSection = '', sidebarSections } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}/favicon.ico`} />
		<title>{title}</title>
	</head>
	<body>
		<ParticleField />
		<ScrollProgress />
		<div class="grain-overlay"></div>

		<div class="split-shell page-enter">
			<header class="split-topbar" data-animate="fade">
				<a class="brand" href={`${import.meta.env.BASE_URL}`}>Link</a>
				<nav>
					<ul class="nav-list">
						{navigation.map((item) => (
							<li>
								<a class:list={[pathname === item.href && 'is-active']} href={`${import.meta.env.BASE_URL}${item.href === '/' ? '' : '/' + item.href.slice(1)}`}>
									{item.label}
								</a>
							</li>
						))}
					</ul>
				</nav>
			</header>

			<div class="split-layout">
				<Sidebar profile={profile} activeSection={activeSection} sections={sidebarSections} />
				<main class="split-content">
					<slot />
					<footer class="split-footer">
						<p>Built with Astro. Static by design.</p>
					</footer>
				</main>
			</div>
		</div>
		<AnimateOnScroll />
	</body>
</html>
