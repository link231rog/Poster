---
import ProjectCard from '../components/ProjectCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjectsPageData, getSiteData } from '../lib/content';

const [site, page] = await Promise.all([getSiteData(), getProjectsPageData()]);
---

<BaseLayout title={`Projects · ${site.seo.title}`} description="Selected engineering and research projects." navigation={site.navigation.items} pathname="/projects">
	<section class="section page-flow">
		<span class="eyebrow" data-animate="fade">Projects</span>
		<h1 class="page-title" data-animate data-delay="100">Work worth opening in a new tab.</h1>
		<p class="page-summary" data-animate data-delay="200">A focused list of shipped, explored, and ongoing work. Each item is concise, linked, and easy to scan.</p>
		<div class="editorial-list projects-listing">
			{page.projects.map((project, i) => (
				<div data-animate data-delay={String(i * 120)}>
					<ProjectCard project={project} />
				</div>
			))}
		</div>
	</section>
</BaseLayout>
