---
import type { BlogPost } from '../types/content';

type Props = {
	post: BlogPost;
};

const { post } = Astro.props;
const dateStr = post.date ? new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '';
---

<article class="blog-card" data-animate data-delay="0">
	<a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="blog-card-link">
		<div class="blog-card-meta">
			<time class="blog-date">{dateStr}</time>
			{post.featured && <span class="blog-featured">Featured</span>}
		</div>
		<h3 class="blog-card-title">{post.title}</h3>
		<p class="blog-card-summary">{post.summary}</p>
		<ul class="tag-list muted-tags">
			{post.tags.map((tag) => <li class="tag">{tag}</li>)}
		</ul>
	</a>
</article>
