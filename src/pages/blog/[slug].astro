---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getBlogPost, getBlogPosts, getSiteData } from '../../lib/content';

export async function getStaticPaths() {
	const posts = await getBlogPosts();
	return posts.map((post) => ({
		params: { slug: post.slug },
	}));
}

const { slug } = Astro.params;
const [site, post] = await Promise.all([getSiteData(), getBlogPost(slug!)]);

if (!post) {
	return Astro.redirect(`${import.meta.env.BASE_URL}blog`);
}

const dateStr = post.date
	? new Date(post.date).toLocaleDateString('en-US', {
			year: 'numeric',
			month: 'long',
			day: 'numeric',
		})
	: '';
---

<BaseLayout title={`${post.title} · ${site.seo.title}`} description={post.summary} navigation={site.navigation.items} pathname="/blog">
	<article class="section page-flow blog-post-page">
		<a href={`${import.meta.env.BASE_URL}blog`} class="back-link" data-animate="fade">← All posts</a>

		<header class="blog-post-header" data-animate data-delay="100">
			<div class="blog-post-meta">
				<time>{dateStr}</time>
				{post.featured && <span class="blog-featured">Featured</span>}
			</div>
			<h1 class="blog-post-title">{post.title}</h1>
			<p class="blog-post-summary">{post.summary}</p>
			<ul class="tag-list muted-tags">
				{post.tags.map((tag) => <li class="tag">{tag}</li>)}
			</ul>
		</header>

		<div class="prose blog-post-body" data-animate data-delay="200" set:html={post.html} />

		<footer class="blog-post-footer" data-animate data-delay="300">
			<NewsletterSignup />
			<a href={`${import.meta.env.BASE_URL}blog`} class="back-link">← Back to all posts</a>
		</footer>
	</article>
</BaseLayout>
