---
import ChinaMap from '../components/ChinaMap.astro';
import PhotoGallery from '../components/PhotoGallery.astro';
import SplitLayout from '../layouts/SplitLayout.astro';
import { getSiteData, getTravelPageData } from '../lib/content';

const [site, page] = await Promise.all([getSiteData(), getTravelPageData()]);

const sidebarSections = [
	{ id: 'map', label: 'Map' },
	{ id: 'photos', label: 'Photos' },
];
---

<SplitLayout
	title={`Travel · ${site.seo.title}`}
	description="Places I've been and photos I've taken."
	navigation={site.navigation.items}
	profile={site.profile}
	pathname="/travel"
	activeSection="map"
	sidebarSections={sidebarSections}
>
	<section id="map" class="split-section">
		<h2 class="section-title">Map</h2>
		<p class="section-desc">{page.locations.length} provinces visited, {page.photos.length} photos and counting.</p>
		<div class="travel-map-section">
			<ChinaMap locations={page.locations} />
			<span class="map-visited-codes" data-visited-codes={page.locations.filter(l => l.visited).map(l => l.code).join(',')} style="display:none"></span>
			<div class="travel-notes">
				{page.locations.filter(l => l.visited).map((loc) => (
					<div class="travel-note">
						<h3>{loc.province}</h3>
						<p class="travel-note-meta">{loc.photos} photos</p>
						{loc.note && <p class="travel-note-text">{loc.note}</p>}
					</div>
				))}
			</div>
		</div>
	</section>

	<section id="photos" class="split-section">
		<h2 class="section-title">Photographs</h2>
		<PhotoGallery photos={page.photos} />
	</section>
</SplitLayout>
